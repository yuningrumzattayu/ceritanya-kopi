<%- include("partials/navbarGuest") %>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    height: 100vh;          /* full tinggi layar */
    background-image: url("/images/header.png");
    background-size: cover;
    background-position: center top;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0;
  }

  .hero-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
  }

  .hero-logo-wrap {
    position: relative;
    z-index: 2;
    background: #fdf6ee;
    border-radius: 12px;
    padding: 12px 18px;
    margin-bottom: 24px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
  }

  .hero-logo-wrap img {
    width: 110px;
    height: auto;
    display: block;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding: 0 1rem;
  }

  .hero-content h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    font-style: italic;
    text-shadow: 0 2px 8px rgba(0,0,0,0.6);
    margin-bottom: 6px;
  }

  .hero-content .tagline {
    font-size: 1.15rem;
    font-weight: 600;
    font-style: italic;
    color: #f0e6d3;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    margin-bottom: 14px;
  }

  .hero-content .description {
    font-size: 1rem;
    color: #e8ddd0;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    margin-bottom: 32px;
  }

  .hero-btn-login,
  .hero-btn-register {
    display: inline-block;
    padding: 10px 36px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition:
      transform 0.15s,
      box-shadow 0.15s;
  }

  .hero-btn-login {
    background-color: #6b8f5e;
    color: #fff;
    border: 2px solid #6b8f5e;
  }

  .hero-btn-login  { margin-right: 12px; }

  .hero-btn-login:hover,
  .hero-btn-register:hover {
    background-color: #577549;
    border-color: #577549;
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(0,0,0,0.3);
  }

  /* Footer langsung nempel di bawah hero, hapus margin */
  footer {
    margin-top: 0 !important;
  }
</style>

<section class="hero-section">
  <div class="hero-logo-wrap">
    <img src="/images/logo.png" alt="Ceritanya Kopi Logo" />
  </div>

  <div class="hero-content">
    <h1>Welcome to Ceritanya Kopi</h1>
    <p class="tagline">Fresh Coffee, Fresh Mood</p>
    <p class="description">Enjoy your favorite coffee anytime and anywhere.</p>
    <a href="/login"    class="hero-btn-login">Login</a>
    <a href="/register" class="hero-btn-register">Register</a>
  </div>
</section>

<%- include("partials/footer") %>
